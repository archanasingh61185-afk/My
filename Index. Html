<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>Jarvis — Ultimate Routing Core v5.5</title>
  
  <script src="https://cdn.tailwindcss.com?plugins=typography"></script>
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <script src="https://js.puter.com/v2/" data-app-key=""></script>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
  
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
    .heading-font { font-family: 'Space Grotesk', sans-serif; }
    
    .custom-scrollbar::-webkit-scrollbar { width: 5px; height: 5px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 99px; }
    
    .orb-wrapper {
      position: relative;
      width: 170px;
      height: 170px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.5s ease-in-out;
    }
    .liquid-boundary {
      position: absolute;
      inset: 0;
      background: linear-gradient(45deg, #1d4ed8, #2563eb, #3b82f6);
      border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
      animation: morphingLiquid 8s infinite ease-in-out;
      filter: blur(1px);
      box-shadow: 0 0 35px rgba(37, 99, 235, 0.5);
      transition: all 0.5s ease-in-out;
    }
    .white-core {
      position: absolute;
      width: 80px;
      height: 80px;
      background: radial-gradient(circle, #ffffff 0%, #f1f5f9 60%, #cbd5e1 100%);
      border-radius: 50%;
      box-shadow: 0 0 25px rgba(255, 255, 255, 0.9);
      z-index: 10;
      transition: all 0.5s ease-in-out;
    }
    
    .live-active .liquid-boundary {
      background: linear-gradient(135deg, #06b6d4, #0ea5e9, #3b82f6, #6366f1);
      animation: morphingLiquid 3s infinite linear;
      box-shadow: 0 0 60px rgba(6, 182, 212, 0.8), 0 0 100px rgba(99, 102, 241, 0.4);
    }
    .live-active .white-core {
      width: 90px;
      height: 90px;
      background: radial-gradient(circle, #ffffff 0%, #e0f2fe 40%, #bae6fd 100%);
      box-shadow: 0 0 40px rgba(255, 255, 255, 1), inset 0 0 15px rgba(14, 165, 233, 0.4);
      animation: pulseCoreLive 1.5s infinite ease-in-out;
    }

    .typing-dot { animation: typing 1.4s infinite ease-in-out both; }
    .typing-dot:nth-child(1) { animation-delay: -0.32s; }
    .typing-dot:nth-child(2) { animation-delay: -0.16s; }
    @keyframes typing { 0%, 80%, 100% { transform: scale(0); } 40% { transform: scale(1); } }
  </style>
</head>
<body id="appBody" class="bg-slate-950 text-slate-100 h-dvh flex flex-col items-center justify-between p-0 overflow-hidden relative transition-colors duration-500 selection:bg-cyan-500/30">

<div class="flex h-full w-full relative overflow-hidden">
  
  <aside id="sidebarMenu" class="fixed inset-y-0 left-0 w-72 bg-slate-900 border-r border-slate-800/80 z-40 transform -translate-x-full transition-transform duration-300 ease-in-out md:relative md:translate-x-0 flex flex-col">
    <div class="p-4 border-b border-slate-800 flex items-center justify-between bg-slate-950">
      <span class="font-bold text-slate-400 tracking-wider text-xs uppercase flex items-center gap-2 heading-font">
        🕒 Core History Stack
      </span>
      <button onclick="clearHistoryLog()" class="text-xs text-rose-400 hover:text-rose-500 transition font-medium">Clear</button>
    </div>
    <div id="historyContainer" class="flex-1 overflow-y-auto p-3 flex flex-col gap-1.5 custom-scrollbar bg-slate-900/40"></div>
    <div class="p-3 bg-slate-950 border-t border-slate-800 text-[10px] text-slate-500 text-center tracking-widest font-mono uppercase">
      Cognitive Matrix Enabled
    </div>
  </aside>

  <div id="sidebarOverlay" onclick="toggleSidebarMenu()" class="fixed inset-0 bg-black/70 backdrop-blur-xs z-30 hidden md:hidden"></div>

  <main class="flex-1 flex flex-col h-full bg-slate-950 relative overflow-hidden">
    
    <header class="flex items-center justify-between px-6 py-4 border-b border-slate-900 bg-slate-900/40 backdrop-blur-md z-20">
      <div class="flex items-center gap-3">
        <button onclick="toggleSidebarMenu()" class="md:hidden text-xs font-semibold px-3 py-1.5 rounded-xl bg-slate-900 border border-slate-800 text-slate-300">
          🕒 Logs
        </button>
        <div id="statusIndicatorDot" class="w-2.5 h-2.5 rounded-full bg-blue-500 shadow-[0_0_10px_#2563eb] animate-pulse"></div>
        <h1 id="appHeaderTitle" class="text-xs font-bold tracking-widest text-slate-400 uppercase heading-font">JARVIS ENGINE</h1>
      </div>
      <div id="engineStatusBadge" class="text-[10px] tracking-wider uppercase font-mono px-3 py-1 rounded-full bg-slate-900 border border-slate-800 text-slate-400 font-medium">
        Standard Router
      </div>
    </header>

    <div id="chatDisplayTerminal" class="flex-1 overflow-y-auto px-4 md:px-8 py-6 flex flex-col gap-6 scroll-smooth custom-scrollbar relative z-10">
      
      <div id="mainPresentationScreen" class="text-center my-auto max-w-lg mx-auto p-8 flex flex-col justify-center items-center gap-8 live-ambient-glow rounded-3xl transition-all duration-500">
        
        <div class="orb-wrapper">
          <div class="liquid-boundary"></div>
          <div class="white-core"></div>
        </div>

        <div class="space-y-2">
          <h2 id="interfaceHeadline" class="text-2xl font-bold text-white tracking-tight heading-font">Welcome, Sir.</h2>
          <p id="interfaceSubtext" class="text-slate-400 text-xs max-w-sm mx-auto leading-relaxed">System parameters stable. Contextual learning matrix initialized.</p>
        </div>
      </div>

    </div>

    <div class="p-4 bg-transparent z-20 w-full max-w-3xl mx-auto relative flex flex-col">
      
      <div id="balanceSystemNotificationBar" class="text-[10px] sm:text-[11px] font-mono text-slate-500/90 text-center mb-2 tracking-wider uppercase transition-colors duration-300">
        Requests Today: 0/10 • Engine Pipeline Operational
      </div>

      <form id="searchComposerForm" class="relative flex items-center gap-2 bg-slate-900/80 border border-slate-800 backdrop-blur-2xl rounded-full pl-5 pr-2 py-2 transition-all focus-within:border-blue-500 focus-within:shadow-[0_0_30px_rgba(37,99,235,0.2)]">
        
        <input type="text" id="queryInputField" class="flex-1 bg-transparent border-0 outline-none text-white text-[15px] py-1.5 placeholder-slate-500 font-medium" placeholder="Ask Jarvis anything..." autocomplete="off">
        
        <button type="submit" id="submitButtonFormNode" class="w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center cursor-pointer transition-all hover:bg-blue-700 active:scale-95 shrink-0 shadow-md shadow-blue-900/30">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
        </button>
      </form>
    </div>

    <div class="w-full flex items-center justify-center overflow-hidden bg-slate-950 border-t border-slate-900 py-1.5 min-h-[58px] z-10">
      <div id="ads-slot-wrapper" class="w-[320px] h-[50px] bg-transparent">
        <script>
          atOptions = {
            'key' : 'c2b62e4c7c731ac598f7dd99d94154b4',
            'format' : 'iframe',
            'height' : 50,
            'width' : 320,
            'params' : {}
          };
        </script>
        <script src="https://www.highperformanceformat.com/c2b62e4c7c731ac598f7dd99d94154b4/invoke.js"></script>
      </div>
    </div>

  </main>
</div>

<script>
  "use strict";

  const SYSTEM_LOGS_CACHE_KEY = "jarvis_clean_router_history_v5";
  const SYSTEM_LIVE_TOGGLE_KEY = "jarvis_assistant_active_v5";
  const REQ_COUNT_KEY = "jarvis_req_count";
  const REQ_DATE_KEY = "jarvis_req_date";

  let appState = {
    isLiveUiActive: localStorage.getItem(SYSTEM_LIVE_TOGGLE_KEY) === "true",
    historyLogs: JSON.parse(localStorage.getItem(SYSTEM_LOGS_CACHE_KEY) || "[]")
  };

  const appBody = document.getElementById("appBody");
  const chatDisplayTerminal = document.getElementById("chatDisplayTerminal");
  const queryInputField = document.getElementById("queryInputField");
  const searchComposerForm = document.getElementById("searchComposerForm");
  const historyContainer = document.getElementById("historyContainer");
  const engineStatusBadge = document.getElementById("engineStatusBadge");
  const mainPresentationScreen = document.getElementById("mainPresentationScreen");
  const interfaceHeadline = document.getElementById("interfaceHeadline");
  const interfaceSubtext = document.getElementById("interfaceSubtext");
  const statusIndicatorDot = document.getElementById("statusIndicatorDot");
  const appHeaderTitle = document.getElementById("appHeaderTitle");
  const submitButtonFormNode = document.getElementById("submitButtonFormNode");
  const balanceSystemNotificationBar = document.getElementById("balanceSystemNotificationBar");

  function bootstrapApplicationRuntime() {
    applyLiveInterfaceThemeState();
    renderHistoryItems();
    initializeDailyLimitSystem();
  }

  function initializeDailyLimitSystem() {
    const todayStr = new Date().toLocaleDateString();
    let savedDate = localStorage.getItem(REQ_DATE_KEY) || "";
    let count = parseInt(localStorage.getItem(REQ_COUNT_KEY) || "0");

    if (savedDate !== todayStr) {
      count = 0;
      localStorage.setItem(REQ_DATE_KEY, todayStr);
      localStorage.setItem(REQ_COUNT_KEY, "0");
    }
    updateRequestCounterDisplay(count);
  }

  function updateRequestCounterDisplay(currentCount) {
    if (appState.isLiveUiActive) {
      balanceSystemNotificationBar.className = "text-[10px] sm:text-[11px] font-mono text-cyan-400/80 text-center mb-2 tracking-wider uppercase drop-shadow-[0_0_8px_rgba(34,211,238,0.3)]";
    } else {
      balanceSystemNotificationBar.className = "text-[10px] sm:text-[11px] font-mono text-slate-500/90 text-center mb-2 tracking-wider uppercase";
    }
    balanceSystemNotificationBar.innerHTML = `Requests Today: ${currentCount}/10 • Dynamic Matrix Pipeline Active`;
  }

  function toggleSidebarMenu() {
    const sidebar = document.getElementById("sidebarMenu");
    const overlay = document.getElementById("sidebarOverlay");
    if (sidebar.classList.contains("-translate-x-full")) {
      sidebar.classList.remove("-translate-x-full");
      overlay.classList.remove("hidden");
    } else {
      sidebar.classList.add("-translate-x-full");
      overlay.classList.add("hidden");
    }
  }

  function applyLiveInterfaceThemeState() {
    if (appState.isLiveUiActive) {
      appBody.classList.add("live-active");
      engineStatusBadge.textContent = "JARVIS INTEL CORE LIVE";
      engineStatusBadge.className = "text-[10px] tracking-wider uppercase font-mono px-3 py-1 rounded-full bg-cyan-950/80 border border-cyan-500/50 text-cyan-400 font-bold shadow-[0_0_12px_rgba(6,182,212,0.3)]";
      statusIndicatorDot.className = "w-2.5 h-2.5 rounded-full bg-cyan-400 shadow-[0_0_12px_#06b6d4] animate-ping";
      appHeaderTitle.className = "text-xs font-bold tracking-widest text-cyan-400 uppercase heading-font";
      
      submitButtonFormNode.className = "w-10 h-10 rounded-full bg-cyan-600 text-white flex items-center justify-center cursor-pointer transition-all hover:bg-cyan-500 active:scale-95 shrink-0 shadow-md shadow-cyan-950/40";
      searchComposerForm.className = "relative flex items-center gap-2 bg-slate-900/90 border border-cyan-500/40 backdrop-blur-2xl rounded-full pl-5 pr-2 py-2 transition-all focus-within:border-cyan-400 focus-within:shadow-[0_0_35px_rgba(6,182,212,0.3)]";
      queryInputField.placeholder = "Ask Jarvis anything...";
      
      interfaceHeadline.textContent = "JARVIS Realtime Quantum Mode";
      interfaceHeadline.className = "text-2xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-white via-cyan-200 to-cyan-400 tracking-tight heading-font";
      interfaceSubtext.textContent = "Deep analytical matrix active. Your history records are continuously indexed for maximum precision answers.";
    } else {
      appBody.classList.remove("live-active");
      engineStatusBadge.textContent = "Standard Router";
      engineStatusBadge.className = "text-[10px] tracking-wider uppercase font-mono px-3 py-1 rounded-full bg-slate-900 border border-slate-800 text-slate-400 font-medium";
      statusIndicatorDot.className = "w-2.5 h-2.5 rounded-full bg-blue-500 shadow-[0_0_10px_#2563eb] animate-pulse";
      appHeaderTitle.className = "text-xs font-bold tracking-widest text-slate-400 uppercase heading-font";
      
      submitButtonFormNode.className = "w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center cursor-pointer transition-all hover:bg-blue-700 active:scale-95 shrink-0 shadow-md shadow-blue-900/30";
      searchComposerForm.className = "relative flex items-center gap-2 bg-slate-900/80 border border-slate-800 backdrop-blur-2xl rounded-full pl-5 pr-2 py-2 transition-all focus-within:border-blue-500 focus-within:shadow-[0_0_30px_rgba(37,99,235,0.2)]";
      queryInputField.placeholder = "Ask Jarvis anything...";
      
      interfaceHeadline.textContent = "Welcome, Sir.";
      interfaceHeadline.className = "text-2xl font-bold text-white tracking-tight heading-font";
      interfaceSubtext.textContent = "System parameters stable. Context memory modules online.";
    }
  }

  function renderHistoryItems() {
    historyContainer.innerHTML = "";
    if (appState.historyLogs.length === 0) {
      historyContainer.innerHTML = `<div class="text-[11px] text-slate-600 text-center py-4 font-mono">No structural records found.</div>`;
      return;
    }
    appState.historyLogs.forEach((logTextString) => {
      const logButtonNode = document.createElement("button");
      logButtonNode.className = "w-full text-left text-[12px] px-3 py-2.5 rounded-xl bg-slate-950 border border-slate-900/60 hover:border-slate-700 hover:bg-slate-900 transition text-slate-300 truncate block font-medium";
      logButtonNode.textContent = logTextString;
      logButtonNode.onclick = () => { queryInputField.value = logTextString; };
      historyContainer.appendChild(logButtonNode);
    });
  }

  function appendQueryToPersistentLog(queryStr) {
    queryStr = queryStr.trim();
    if (!queryStr) return;
    appState.historyLogs = appState.historyLogs.filter(entry => entry.toLowerCase() !== queryStr.toLowerCase());
    appState.historyLogs.unshift(queryStr);
    if (appState.historyLogs.length > 35) appState.historyLogs.pop();
    localStorage.setItem(SYSTEM_LOGS_CACHE_KEY, JSON.stringify(appState.historyLogs));
    renderHistoryItems();
  }

  async function handleSearchExecutionSequence(text) {
    text = text.trim();
    if (!text) return;

    const todayStr = new Date().toLocaleDateString();
    let savedDate = localStorage.getItem(REQ_DATE_KEY) || "";
    let count = parseInt(localStorage.getItem(REQ_COUNT_KEY) || "0");

    if (savedDate !== todayStr) {
      count = 0;
      localStorage.setItem(REQ_DATE_KEY, todayStr);
    }

    if (count >= 10) {
      mainPresentationScreen.style.display = "none";
      appendChatMessageElementRow("user", text);
      const limitExhaustedTrackingId = "limit-node-" + Date.now();
      appendChatMessageElementRow("assistant", `<b>Limit Reached:</b> Sir, your daily limit of 10 requests has been exhausted. Please try again tomorrow.`, limitExhaustedTrackingId, true);
      triggerBeepAudioTone(250, 0.3);
      return;
    }

    count++;
    localStorage.setItem(REQ_COUNT_KEY, count.toString());
    updateRequestCounterDisplay(count);

    appendQueryToPersistentLog(text);
    mainPresentationScreen.style.display = "none";
    
    appendChatMessageElementRow("user", text);
    const trackingBubbleIdentifierCode = "response-node-" + Date.now();
    appendChatMessageElementRow("assistant", `<div class="flex gap-1.5 py-1.5"><div class="w-1.5 h-1.5 bg-cyan-400 rounded-full typing-dot"></div><div class="w-1.5 h-1.5 bg-cyan-400 rounded-full typing-dot"></div><div class="w-1.5 h-1.5 bg-cyan-400 rounded-full typing-dot"></div></div>`, trackingBubbleIdentifierCode, true);

    await new Promise(resolve => setTimeout(resolve, 2000));

    let historicDeepContextString = "";
    if (appState.historyLogs.length > 0) {
      historicDeepContextString = "\n[Historical Session Context logs]: " + appState.historyLogs.slice(0, 10).join(" -> ");
    }

    try {
      let structuredAiPayload = [
        { 
          role: "system", 
          content: "You are JARVIS, an elite artificial intelligence computational core. Speak with absolute mastery, supreme intelligence, and clear logical structure. Address the user as Sir. Use the provided historical session context logs to trace if the user is asking questions related to past inquiries like machine learning, development pipelines, or specific modules, and provide a significantly improved, contextualized, high-tier answer." + historicDeepContextString 
        },
        { role: "user", content: text }
      ];

      const cloudEvaluationResult = await puter.ai.chat(structuredAiPayload, { model: "gpt-4o" });
      let resolvedOutputPayloadString = typeof cloudEvaluationResult === "string" ? cloudEvaluationResult : (cloudEvaluationResult?.message?.content || cloudEvaluationResult?.text || "Pipeline processing disconnect fault.");

      const verifiedTargetContainer = document.getElementById(trackingBubbleIdentifierCode);
      if (verifiedTargetContainer) {
        verifiedTargetContainer.innerHTML = marked.parse(resolvedOutputPayloadString);
        verifiedTargetContainer.classList.add("prose", "prose-invert", "prose-sm", "max-w-none");
      }
    } catch (error) {
      const fallbackUrlPath = `https://www.google.com/search?q=${encodeURIComponent(text)}`;
      window.open(fallbackUrlPath, '_blank');
      document.getElementById(trackingBubbleIdentifierCode).innerHTML = `<b>Ecosystem Engine Route:</b> Neural pipeline fault. Fallback query executed for: <i>"${text}"</i>.`;
    }
  }

  function appendChatMessageElementRow(role, content, id = null, isRawHTML = false) {
    const componentWrapperRowNode = document.createElement("div");
    componentWrapperRowNode.className = `flex w-full ${role === 'user' ? 'justify-end' : 'justify-start'}`;
    const targetParsedInnerMarkup = isRawHTML ? content : marked.parse(content || "");
    
    componentWrapperRowNode.innerHTML = `
      <div id="${id || ''}" class="max-w-[85%] text-[14px] px-5 py-3.5 rounded-2xl border ${
        role === 'user' 
          ? (appState.isLiveUiActive ? 'bg-cyan-600 border-cyan-500' : 'bg-blue-600 border-blue-500') + ' text-white rounded-tr-none shadow-md shadow-slate-950/40' 
          : 'bg-slate-900 border-slate-800 text-slate-100 rounded-tl-none shadow-sm'
      }">${targetParsedInnerMarkup}</div>
    `;
    chatDisplayTerminal.appendChild(componentWrapperRowNode);
    chatDisplayTerminal.scrollTop = chatDisplayTerminal.scrollHeight;
  }

  searchComposerForm.onsubmit = event => { 
    event.preventDefault(); 
    const elementValueSnapshot = queryInputField.value; 
    queryInputField.value = ""; 
    handleSearchExecutionSequence(elementValueSnapshot); 
  };
  
  function clearHistoryLog() { 
    if (confirm("Purge history stack trace parameters?")) { 
      appState.historyLogs = []; 
      localStorage.removeItem(SYSTEM_LOGS_CACHE_KEY); 
      renderHistoryItems(); 
    } 
  }

  function triggerBeepAudioTone(frequencyVal, durationLengthValue) {
    try {
      const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      const oscillator = audioCtx.createOscillator();
      const gainNode = audioCtx.createGain();
      oscillator.type = "sine";
      oscillator.frequency.setValueAtTime(frequencyVal, audioCtx.currentTime);
      gainNode.gain.setValueAtTime(0.06, audioCtx.currentTime);
      gainNode.gain.exponentialRampToValueAtTime(0.002, audioCtx.currentTime + durationLengthValue);
      oscillator.connect(gainNode);
      gainNode.connect(audioCtx.destination);
      oscillator.start();
      oscillator.stop(audioCtx.currentTime + durationLengthValue);
    } catch (e) {}
  }
  
  window.onload = bootstrapApplicationRuntime;
</script>
</body>
</html>
